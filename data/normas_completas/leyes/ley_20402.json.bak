  "titulo": "LEY 20402 CREA EL MINISTERIO DE ENERGÍA, ESTABLECIENDO MODIFICACIONES AL DL Nº 2.224, DE 1978 Y A OTROS CUERPOS LEGALES",
  "fecha_publicacion": "",
  "fecha_promulgacion": null,
  "organismo": "",
  "estado": "DESCONOCIDO",
